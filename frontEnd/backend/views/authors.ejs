<%- include('partials/head') %>

<h1><%= title %></h1>
<p class="muted">Rendered by <code>pagesController.authors</code> → <code>views/authors.ejs</code></p>

<% if (authors.length === 0) { %>
  <div class="card">No authors yet.</div>
<% } else { %>
  <% authors.forEach(function(author) { %>
    <article class="card">
      <h2><%= author.name %></h2>
      <p><%= author.bio || 'No bio' %></p>
      <p class="muted"><%= author.email %></p>
    </article>
  <% }); %>
<% } %>

<%- include('partials/foot') %>
