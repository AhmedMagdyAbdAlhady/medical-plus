<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | Course App</title>
  <style>
    * { box-sizing: border-box; }
    body {
      font-family: system-ui, -apple-system, sans-serif;
      margin: 0;
      background: #f4f6f8;
      color: #1a1a2e;
    }
    header {
      background: #16213e;
      color: #fff;
      padding: 1rem 1.5rem;
    }
    header a { color: #e8e8e8; margin-right: 1rem; text-decoration: none; }
    header a:hover { text-decoration: underline; }
    main { max-width: 900px; margin: 1.5rem auto; padding: 0 1rem; }
    .card {
      background: #fff;
      border-radius: 8px;
      padding: 1rem 1.25rem;
      margin-bottom: 1rem;
      box-shadow: 0 1px 3px rgba(0,0,0,.08);
    }
    .muted { color: #666; font-size: 0.9rem; }
    h1 { margin-top: 0; }
    ul { padding-left: 1.25rem; }
    .badge {
      display: inline-block;
      background: #e8f4fc;
      color: #0d47a1;
      padding: 0.15rem 0.5rem;
      border-radius: 4px;
      font-size: 0.85rem;
    }
    footer {
      text-align: center;
      padding: 2rem;
      color: #888;
      font-size: 0.85rem;
    }
  </style>
</head>
<body>
  <header>
    <nav>
      <a href="/">Home</a>
      <a href="/courses">Courses (View)</a>
      <a href="/authors">Authors (View)</a>
      <a href="/api/courses">API: Courses</a>
    </nav>
  </header>
