<%- include('partials/head') %>

<h1><%= title %></h1>
<p class="muted">Rendered by <code>pagesController.courses</code> → <code>views/courses.ejs</code></p>

<% if (courses.length === 0) { %>
  <div class="card">No courses yet. Add some via Postman or the API.</div>
<% } else { %>
  <% courses.forEach(function(course) { %>
    <article class="card">
      <h2><%= course.title %></h2>
      <p><%= course.description || 'No description' %></p>
      <p>
        <span class="badge"><%= course.category %></span>
        <% if (course.price != null) { %>
          · $<%= course.price %>
        <% } %>
        <% if (course.isPublished) { %>
          · Published
        <% } %>
      </p>
      <% if (course.author) { %>
        <p class="muted">Author: <%= course.author.name %> (<%= course.author.email %>)</p>
      <% } %>
    </article>
  <% }); %>
<% } %>

<%- include('partials/foot') %>
